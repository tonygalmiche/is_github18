<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="is_view_company_form_github" model="ir.ui.view">
            <field name="name">is_view_company_form_github</field>
            <field name="model">res.company</field>
            <field name="inherit_id" ref="base.view_company_form"/>
            <field name="arch" type="xml">
                <notebook position="inside">
                    <page string="Github" name="github">
                        <group>
                            <field name="is_github_key" password="True"/>
                        </group>
                    </page>
                </notebook>
            </field>
        </record>
    </data>
</odoo>
